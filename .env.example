# =============================================================================
# SaaS monorepo – API keys and secrets (root .env)
# On localhost, place your real keys in .env (or .env.local) in this root folder.
# All apps (BrainDump, ReelRecorder, VideoQuiz, etc.) load from here.
# =============================================================================

# --- OpenAI (transcription, captions, AI features) ---
OPENAI_API_KEY=

# --- Database (BrainDump – Postgres) ---
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# --- Auth (BrainDump – Google OAuth) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stock media (ReelRecorder, VideoQuiz, shared pickers) ---
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
GIPHY_API_KEY=
PIXABAY_API_KEY=

# --- Optional: ElevenLabs (SoundEffectsGenerator, voice) ---
ELEVENLABS_API_KEY=

# --- Next.js public (client-side; set if you need keys in browser for an app) ---
# NEXT_PUBLIC_OPENAI_API_KEY=
# NEXT_PUBLIC_BASE_PATH=

# --- Vite client (optional; if not set, apps may use localStorage or server) ---
# VITE_OPENAI_API_KEY=
# VITE_GIPHY_API_KEY=
# VITE_PEXELS_API_KEY=
# VITE_UNSPLASH_ACCESS_KEY=
# VITE_PIXABAY_API_KEY=
