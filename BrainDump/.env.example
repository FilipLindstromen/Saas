# Postgres connection string (from Vercel Storage, Neon, etc.)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Server-side API keys and OAuth credentials (set by the developer, not end users)
OPENAI_API_KEY="your-openai-api-key"

# Google OAuth for BrainDump login (Auth.js / NextAuth)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Optional: stock media (used by ReelRecorder / shared pickers; set if you use those features)
UNSPLASH_ACCESS_KEY="your-unsplash-access-key"
PEXELS_API_KEY="your-pexels-api-key"
GIPHY_API_KEY="your-giphy-api-key"
