// BrainDump - Voice capture and thought organization
// Database schema for dumps, organized items, projects, and tags

generator client {
  provider = "prisma-client"
  output   = "generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Dump {
  id                String    @id @default(cuid())
  mode              String    @default("inbox") // inbox | work | personal
  userId            String
  audioUrl          String?   // reference to stored audio (URL or blob key)
  transcriptRaw     String    @default("")
  transcriptEdited  String    @default("")
  status            String    @default("draft") // draft | transcribed | organized | saved
  createdAt         DateTime  @default(now())
  organizedAt       DateTime?
  updatedAt         DateTime  @updatedAt

  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizedItems   OrganizedItem[]

  @@index([userId, mode, status])
  @@index([userId, createdAt])
}

model OrganizedItem {
  id               String    @id @default(cuid())
  dumpId           String
  userId           String
  domain           String    // inbox | work | personal
  category         String
  subcategory      String    @default("")
  projectId        String?
  itemType         String    // task | note | idea | emotion | reflection | reminder | problem | decision | journal_entry | project_update
  title            String
  content          String    @default("")
  emotionLabel     String?
  status           String    @default("draft") // draft | needs_review | approved | saved
  progress         String    @default("todo")  // todo | started | completed
  priority         Int?      // nullable
  recommendedView  String    @default("note_cards")
  confidenceScore   Float     @default(0)
  positionX        Float?    // for kanban/post-its layout
  positionY        Float?
  kanbanColumn     String?   // e.g. todo | started | completed
  scheduledAt      DateTime? // date/time for calendar (date part = day, time optional)
  scheduledTime    String?   // e.g. "09:00" for display/notification
  recurrence       String?   // none | daily | weekly | monthly
  sendNotification Boolean?  @default(false)
  reminderAt             DateTime? // when to send the main reminder notification
  reminderMinutesBefore  Int?     // also notify this many minutes before (0 = no early notification)
  reminderNotifiedAt     DateTime? // set when main reminder was sent
  reminderEarlyNotifiedAt DateTime? // set when early (X min before) reminder was sent
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  dump     Dump     @relation(fields: [dumpId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tags     OrganizedItemTag[]

  @@index([userId, dumpId])
  @@index([userId, domain, category])
  @@index([userId, projectId])
  @@index([userId, itemType])
  @@index([userId, status])
  @@index([userId, scheduledAt])
}

model Project {
  id          String    @id @default(cuid())
  name        String
  domain      String    @default("work") // work | personal
  description String    @default("")
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrganizedItem[]
}

model Tag {
  id   String @id @default(cuid())
  name String
  userId String

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  items OrganizedItemTag[]

  @@unique([userId, name])
}

model OrganizedItemTag {
  itemId String
  tagId  String

  item OrganizedItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag  Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
  @@index([tagId])
}

/// Auth.js / NextAuth user model (credentials: passwordHash set; OAuth: accounts used)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?    // for email/password sign-in only

  accounts  Account[]
  sessions  Session[]
  dumps     Dump[]
  items     OrganizedItem[]
  projects  Project[]
  tags      Tag[]
}

/// Auth.js / NextAuth account model
model Account {
  userId                 String
  type                   String
  provider               String
  providerAccountId      String
  refresh_token          String?  @db.Text
  access_token           String?  @db.Text
  expires_at             Int?
  token_type             String?
  scope                  String?
  id_token               String?  @db.Text
  session_state          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

/// Auth.js / NextAuth session model
model Session {
  sessionToken String  @id
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Auth.js / NextAuth email verification / magic link tokens
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
